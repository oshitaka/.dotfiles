{
    //WORKSPACES
    "hyprland/workspaces": {
	      "active-only":false,
        "all-outputs": true,
        "format": "{icon}",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "show-special": false,
        "persistent-workspaces":{
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        },
        "format-icons": {
            "active": "≤░χψ",
            "default": "≤░Λι",
            "persistent":"≤░Λι",
            "empty": "ΎΣΕ"
        }
    },

    "custom/separator": {
        "format": "",
        "interval": "once",
        "tooltip": false
    },

    "group/indicators": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory",
            "temperature",
            "disk",
            "battery",
            "power-profiles-daemon"
        ]
    },

    "group/main": {
        "orientation": "horizontal",
        "modules": [
            "bluetooth",
            "network",
            "backlight",
            "wireplumber"
        ]
    },

     
    //indicators
    "cpu": {
        "interval": 1,
        "format": "ΎΤ╝ {usage}%"
    },
    "disk": {
        "interval": 30,
        "path": "/",
        "format": "ΌΚ▒ {percentage_used}%",
        "tooltip": true,
        "tooltip-format": "{used} used out of {total} on {path} ({percentage_used}%)"
    },
    "temperature": {
        "interval": 10,
        "tooltip": false,
        "thermal-zone": 2,
        "hwmon-path": [
            "/sys/class/hwmon/hwmon2/temp1_input" 
            //"/sys/class/thermal/thermal_zone2/temp"
        ],
        "critical-threshold": 85,
        "format-critical": "{icon}{temperatureC}┬░C",
        "format": "{icon}{temperatureC}┬░C",
        "format-icons": ["ΎΜΛ ", "ΎΜΚ ", "ΎΜΘ "],
        "on-click-right": "kitty --title btop sh -c 'btop'"
    },
    "memory": {
        "interval": 10,
        "format-alt": "≤░Ξε {used:0.1f}G",
        "format": "≤░Ξε {percentage}%",
        "format-alt-click": "click",
        "tooltip": true,
        "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
        "on-click-right": "kitty --title btop sh -c 'btop'"
    },
    "battery": {
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "format": "{capacity}% {icon}",
      "format-charging": "ΎΔπ {capacity}%",
      "format-plugged": "ΎΘο {capacity}%",
      "format-alt": "{icon} {time}",
      "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
      "max-length": 25
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ΎΔπ",
        "performance": "ΎΔπ",
        "balanced": "ΎΚΟ",
        "power-saver": "ΎΒυ"
      }
    },

    //main
    "bluetooth": {
        "format-connected": "≤░Γ▒",
        "format-no-controller": "≤░Γ▓",
        "format-disabled": "≤░Γ▓",
        "format-off": "≤░Γ▓",
        "format-on": "ΎΛΦ",
        "format-connected-battery": "{icon}",
        // "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "format-icons": ["≤░ν╛", "≤░ν┐", "≤░ξΑ", "≤░ξΒ", "≤░ξΓ", "≤░ξΔ", "≤░ξΕ", "≤░ξΖ", "≤░ξΗ", "≤░ξΙ"],
        "on-click": "exec blueman-manager"
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "{icon}",
        "format-ethernet": "≤░Να",
        "format-disconnected": "≤░Νβ", 
        "tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
        "format-linked": "≤░ΙΒ {ifname} (No IP)",
        "tooltip-format-wifi": "{essid} {icon} {signalStrength}%\n\n{ipaddr} ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
        "tooltip-format-ethernet": "{ifname} ≤░Να",
        "tooltip-format-disconnected": "≤░Νβ Disconnected",
        "max-length": 50,
        "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"]
    },
    "backlight": {
      // "device": "acpi_video1",
      "format": "≤░Δθ",
      "tooltip-format": "Brightness: {percent}%"
    },
    "wireplumber": {
      "format": "{icon}",
      "format-muted": "≤░╕Ι",
      "on-click": "pavucontrol",
      "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
      "tooltip-format": "Volume: {volume}%"
    },
    "clock": {
        "interval": 1,
        "format-alt": "ΎΑΩ {:%H:%M:%S}",
        "format": "ΎΒ│ {:%d.%m.%Y ΎΑΩ %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },             
        "actions":  {
          "on-click-right": "mode",
          "on-click-forward": "tz_up",
          "on-click-backward": "tz_down",
          "on-scroll-up": "shift_up",
          "on-scroll-down": "shift_down"
        }
    },
 
    "custom/weather": {
        "format": "{} ",
        "tooltip": true,
        "interval": 60,
        "exec": "bash ~/.config/waybar/scripts/weather.sh",
        "return-type": "json",
        "on-click": "exec bash ~/.config/waybar/scripts/weather.sh"
    },
    
    "tray": {
      "icon-size": 12,
      "spacing": 8
    },

    "hyprland/language": {
        "format": "{}",
        "format-en": "US",
        "format-ru": "RU",
        "keyboard-name": "gaming-keyboard",
        "on-click": "hyprctl switchxkblayout gaming-keyboard next"
    },

    "custom/ip": {
      "format": "{}",
      "exec": "curl -s www.icanhazip.com",
      "interval": 30
    },
    
    "custom/cmus": {
      "format": "έβς {}",
      //"max-length": 15,
      "interval": 10,
      "exec": "cmus-remote -C \"format_print '%a - %t'\"", // artist - title
      "exec-if": "pgrep cmus",
      "on-click": "cmus-remote -u",                        //toggle pause
      "escape": true                                       //handle markup entities
    },

    "network#speed": {
      "format": "ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}"
    },

    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "ΎΒχ",
        "deactivated": "ΎΒ░"
      }
    }

